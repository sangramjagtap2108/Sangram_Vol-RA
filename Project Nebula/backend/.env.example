# Example environment variables - DO NOT ADD REAL CREDENTIALS HERE
# Local example:
MONGO_URI=mongodb://localhost:27017/nebula
# Production (Railway/Atlas) should use a real cloud URI, for example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_complex
ALLOWED_ORIGINS=http://localhost:3000,https://project-nebula-frontend-production.up.railway.app

# Email Configuration (Gmail)
# To get an app password for Gmail:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to Google Account Settings > Security > App passwords
# 3. Generate an app password for this application
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password